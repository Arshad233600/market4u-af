# Azure Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=market4ustorage01;AccountKey=your_account_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=product-images

# Azure SQL Configuration
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=market4u-db
DB_SERVER=market4u-sql-server.database.windows.net
SqlConnectionString=Server=tcp:market4u-sql-server.database.windows.net,1433;Initial Catalog=market4u-db;Persist Security Info=False;User ID=your_username;Password=your_password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;ApplicationName=market4u-api;
AZURE_SQL_CONNECTION_STRING=Server=tcp:market4u-sql-server.database.windows.net,1433;Initial Catalog=market4u-db;Persist Security Info=False;User ID=your_username;Password=your_password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;ApplicationName=market4u-api;
# All-caps alias accepted by db.ts and the GitHub Actions workflow (GitHub Secrets are case-sensitive)
SQLCONNECTIONSTRING=Server=tcp:market4u-sql-server.database.windows.net,1433;Initial Catalog=market4u-db;Persist Security Info=False;User ID=your_username;Password=your_password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;ApplicationName=market4u-api;

# Auth Secret — REQUIRED for token signing and verification.
# Generate with: openssl rand -hex 32
# IMPORTANT: This must be set to a real random value in Azure Static Web App →
# Configuration → Application settings. Do NOT set it to "VITE_API_BASE_URL" or
# any other variable name — it must be a long random string (minimum 32 characters).
# All backend instances must share the same AUTH_SECRET value; mismatched secrets
# will cause 401 invalid_token errors for all authenticated requests.
AUTH_SECRET=change-this-to-a-random-string-min-32-characters-long

# Gemini API Configuration
GEMINI_API_KEY=

# Monitoring
APPLICATIONINSIGHTS_CONNECTION_STRING=

# API base URL (resolved by apiClient.ts)
# In production (Azure Static Web App) this MUST be set to /api so all requests
# are routed through the SWA same-origin proxy rather than a direct Function App URL.
# Setting this to an absolute azurewebsites.net URL will bypass the SWA auth
# middleware and cause CORS / 401 errors.
# After changing this value in Azure Static Web App → Configuration → Environment
# variables you MUST redeploy (or trigger a new build) for the change to take effect.
VITE_API_BASE_URL=/api

# Auth diagnostics (set to true to enable console debug logging for auth flows)
# NEVER enable in production unless actively debugging a live incident.
# Logs token presence (boolean only — never the token value), localStorage
# availability, cookie count, and every API request path + status + auth flag.
VITE_DEBUG_AUTH=false

# Auth diag endpoint (GET /api/auth/diag)
# Set AUTH_DIAG_ENABLED=true in Azure Application Settings to expose the endpoint.
# Set DIAG_ALLOWLIST to a comma-separated list of allowed X-Diag-Allowlist header values.
AUTH_DIAG_ENABLED=false
DIAG_ALLOWLIST=

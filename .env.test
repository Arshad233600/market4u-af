# ============================================================
# TEST ENVIRONMENT CONFIGURATION
# ============================================================
# SAFE TO COMMIT — all values are test-only placeholders.
# Tests NEVER connect to the production database.
# The TEST_SQLCONNECTIONSTRING env var is intentionally empty so
# db.ts throws and the mock DB adapter is used in tests instead.
# ============================================================

# Auth — use a long random value so AUTH_SECRET length checks pass
AUTH_SECRET=test-auth-secret-value-that-is-at-least-32-chars-long-for-tests

# SQL — leave empty so db.ts throws on any un-mocked DB call, ensuring
# tests never accidentally hit a real database.
TEST_SQLCONNECTIONSTRING=
SqlConnectionString=
SQLCONNECTIONSTRING=
AZURE_SQL_CONNECTION_STRING=

# Azure Storage — intentionally missing; upload tests use mock adapters
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=test-container

# Frontend
VITE_API_BASE_URL=http://localhost:7071/api
VITE_USE_MOCK_DATA=false
VITE_DEBUG_AUTH=false

# Diagnostics
AUTH_DIAG_ENABLED=false
DIAG_ALLOWLIST=

# Gemini / App Insights — not used in tests
GEMINI_API_KEY=
APPLICATIONINSIGHTS_CONNECTION_STRING=

NODE_ENV=test

# Azure SQL Database Configuration
# Option 1: Use connection string (recommended for production)
SqlConnectionString=Server=tcp:market4u-sql-server.database.windows.net,1433;Initial Catalog=market4u-db;Persist Security Info=False;User ID=your_username;Password=your_password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;ApplicationName=market4u-api;

# Option 2: Use individual parameters
# DB_SERVER=market4u-sql-server.database.windows.net
# DB_NAME=market4u-db
# DB_USER=your_username
# DB_PASSWORD=your_password

# Authentication Secret (REQUIRED in production)
# Generate a real random secret with: openssl rand -hex 32
# Replace the dev default below before deploying to Azure.
AUTH_SECRET=dev-local-replace-before-deploying-to-azure-production

# Azure Blob Storage (for image uploads)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=market4ustorage01;AccountKey=your_account_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=ads-images

# Google Gemini API (optional, for AI features)
GEMINI_API_KEY=your-gemini-api-key

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key

# Auth diag endpoint (GET /api/auth/diag)
# Set to true to enable. Pair with DIAG_ALLOWLIST for access control.
AUTH_DIAG_ENABLED=false
DIAG_ALLOWLIST=

# Distributed Rate Limiting (BUG-001 fix)
# Set to an Azure Cache for Redis connection string to enable the distributed
# rate-limit store.  When not set, the in-memory store is used (local dev only).
# Azure Cache for Redis format:
#   <hostname>.redis.cache.windows.net:6380,password=<access-key>,ssl=True,abortConnect=False
# ioredis URL format (used by this app):
#   rediss://:<access-key>@<hostname>.redis.cache.windows.net:6380
RATE_LIMIT_REDIS_URL=

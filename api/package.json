{
  "name": "market4u-api",
  "version": "1.0.0",
  "description": "Azure Functions Backend for Market4U",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "func start --javascript --script-root dist",
    "lint:types": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@azure/functions": "^4.7.0",
    "@azure/identity": "^4.8.0",
    "@azure/storage-blob": "^12.26.0",
    "@google/genai": "^1.1.0",
    "applicationinsights": "3.13.0",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.17.30",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "glob": "^13.0.0",
    "minimatch": ">=8.0.6",
    "fast-xml-parser": "^5.5.3",
    "node-domexception": "^2.0.2"
  }
}
